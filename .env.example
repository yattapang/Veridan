# Supabase project URL (Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anonymous/public API key (safe for browser use, RLS-protected)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Supabase service-role key (server-only; bypasses RLS — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Resend API key for transactional email (https://resend.com/api-keys)
RESEND_API_KEY=re_your-api-key
# Anthropic API key for the supplier-quote scanner's Claude extraction pipeline
# (Phase 2B Task 37). Server-only; the founders pay per extraction call. Without
# it, POST /api/price-files/[id]/extract fails with a clear "add this key" error.
ANTHROPIC_API_KEY=
# Canonical site URL, no trailing slash (e.g. https://veridanlimited.com; http://localhost:3000 in dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
